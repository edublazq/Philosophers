{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/cc",
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "c11",
      "defines": [
        "_DEFAULT_SOURCE",
        "_XOPEN_SOURCE=700"
      ],
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/philo/include",
        "/usr/include",
        "/usr/local/include"
      ]
    }
  ]
}